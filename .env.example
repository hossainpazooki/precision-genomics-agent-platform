# Application
APP_NAME="Precision Genomics Agent Platform"
ENVIRONMENT=local
DEBUG=true

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/precision_genomics

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic (LLM)
# ANTHROPIC_API_KEY=

# Data paths
DATA_DIR=data
RAW_DATA_DIR=data/raw

# ML settings
RANDOM_STATE=42
CV_FOLDS=10
N_ESTIMATORS=500

# Auth
REQUIRE_AUTH=false
# API_KEYS=key1,key2

# Feature flags
ENABLE_FEATURE_STORE=true

# Temporal (workflows)
# TEMPORAL_HOST=localhost:7233
# TEMPORAL_NAMESPACE=default
# TEMPORAL_TASK_QUEUE=genomics-workflows
